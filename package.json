{
  "name": "@alsania-io/devcon-x",
  "version": "1.0.0",
  "private": true,
  "description": "Root package for DevConX monorepo",
  "repository": "https://github.com/alsania-dev/devconx",
  "license": "Apache-2.0",
  "type": "module",
  "workspaces": [
    "extensions/vscode"
  ],
  "scripts": {
    "build": "cd extensions/vscode && npm run build",
    "lint": "cd extensions/vscode && npm run lint",
